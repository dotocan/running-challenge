---
// src/pages/index.astro
import "../styles/global.css";
import LiveDashboard from "../components/LiveDashboard.astro";
import DashboardStats from "../components/DashboardStats.astro";
import { getDashboardCache } from "../lib/db";
import type { DashboardData } from "../lib/strava";

let cachedData: DashboardData | null = await getDashboardCache();

// Fallback empty state if entirely no cache
if (!cachedData) {
  cachedData = {
    activities: [],
    totalDistance: 0,
    totalOverallDistance: 0,
    runCount: 0,
    errorMsg: ""
  };
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Running Dashboard</title>
  </head>
  <body class="bg-gray-100 min-h-screen font-sans">
    <main class="max-w-4xl mx-auto p-6">
      <header class="mb-8 text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
          Running Challenge
        </h1>
        <p class="text-gray-600">15.01.2026 - 01.07.2026</p>
      </header>

      <LiveDashboard server:defer>
        <DashboardStats slot="fallback" data={cachedData} isRefreshing={true} />
      </LiveDashboard>
    </main>
  </body>
</html>
