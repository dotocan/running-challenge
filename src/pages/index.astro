---
// src/pages/index.astro
import "../styles/global.css";
import DashboardStats from "../components/DashboardStats.astro";
import { fetchDashboardData } from "../lib/strava";

const data = await fetchDashboardData();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Running Dashboard</title>
  </head>
  <body class="bg-gray-100 min-h-screen font-sans">
    <main class="max-w-4xl mx-auto p-6">
      <header class="mb-8 text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
          Running Challenge
        </h1>
        <p class="text-gray-600">15.01.2026 - 01.07.2026</p>
      </header>

      <DashboardStats data={data} isRefreshing={false} />
    </main>
  </body>
</html>
